{
  "version": 1,
  "sdk_version": "0.23.0",
  "path": "/mcp",
  "auth": {
    "type": "oauth",
    "issuer": "https://oymxgjnstkfpqsmcezag.supabase.co/auth/v1",
    "accepted_audiences": [
      "authenticated"
    ]
  },
  "mcp": {
    "server": {
      "name": "one-way-cab-mcp",
      "version": "0.1.0",
      "title": "ONE WAY CAB — Agent tools"
    },
    "tools": [
      {
        "name": "list_my_bookings",
        "title": "List my bookings",
        "description": "List the signed-in user's cab bookings, most recent first. Returns booking ref, status, pickup/drop cities, date, vehicle, and fare.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "limit": {
              "type": "integer",
              "default": 20,
              "description": "Maximum number of bookings to return (default 20)."
            }
          },
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      },
      {
        "name": "list_my_coupons",
        "title": "List my coupons",
        "description": "Return coupons issued to the signed-in user (via their travel leads), with code, discount percent, and expiry.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {}
        },
        "outputSchema": null
      },
      {
        "name": "create_travel_lead",
        "title": "Create travel lead",
        "description": "Submit a new travel enquiry for the signed-in user. The sales team is notified and the app issues a coupon.",
        "annotations": {
          "readOnlyHint": false,
          "destructiveHint": false,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string",
              "description": "Customer full name."
            },
            "phone": {
              "type": "string",
              "description": "Customer phone number, digits and + only."
            },
            "email": {
              "type": "string",
              "description": "Customer email address."
            },
            "origin_city": {
              "type": "string",
              "description": "City the traveller is departing from."
            },
            "destination": {
              "type": "string",
              "description": "Destination city or region."
            },
            "travel_date": {
              "type": "string",
              "description": "Planned travel date (YYYY-MM-DD)."
            },
            "travelers": {
              "type": "integer",
              "default": 2,
              "description": "Number of travellers."
            },
            "state": {
              "type": [
                "string",
                "null"
              ],
              "default": null,
              "description": "Optional state / region."
            },
            "budget_range": {
              "type": [
                "string",
                "null"
              ],
              "default": null,
              "description": "Optional budget range."
            },
            "notes": {
              "type": [
                "string",
                "null"
              ],
              "default": null,
              "description": "Optional free-text notes."
            }
          },
          "required": [
            "name",
            "phone",
            "email",
            "origin_city",
            "destination",
            "travel_date"
          ],
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      }
    ]
  }
}
